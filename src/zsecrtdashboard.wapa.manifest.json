        "TargetmiscRepDashboard": {                                                                                                                                                                                                                            
          "viewType": "XML",                                                                                                                                                                                                                                   
          "transition": "slide",                                                                                                                                                                                                                               
          "clearControlAggregation": false,                                                                                                                                                                                                                    
          "viewId": "miscRepDashboard",                                                                                                                                                                                                                        
          "viewName": "miscRepDashboard"                                                                                                                                                                                                                       
        }                                                                                                                                                                                                                                                      
      }                                                                                                                                                                                                                                                        
    },                                                                                                                                                                                                                                                         
    "rootView": {                                                                                                                                                                                                                                              
      "viewName": "com.securitydashboard.zsecdashboard.view.App",                                                                                                                                                                                              
      "type": "XML",                                                                                                                                                                                                                                           
      "async": true,                                                                                                                                                                                                                                           
      "id": "App"                                                                                                                                                                                                                                              
    }                                                                                                                                                                                                                                                          
