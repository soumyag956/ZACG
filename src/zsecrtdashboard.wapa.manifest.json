        "viewType": "XML",                                                                                                                                                                                                                                     
        "async": true,                                                                                                                                                                                                                                         
        "viewPath": "com.securitydashboard.zsecdashboard.view",                                                                                                                                                                                                
        "controlAggregation": "pages",                                                                                                                                                                                                                         
        "controlId": "app",                                                                                                                                                                                                                                    
        "clearControlAggregation": false                                                                                                                                                                                                                       
      },                                                                                                                                                                                                                                                       
      "routes": [                                                                                                                                                                                                                                              
        {                                                                                                                                                                                                                                                      
          "name": "RoutemiscRepDashboard",                                                                                                                                                                                                                     
          "pattern": ":?query:",                                                                                                                                                                                                                               
          "target": [                                                                                                                                                                                                                                          
            "TargetmiscRepDashboard"                                                                                                                                                                                                                           
          ]                                                                                                                                                                                                                                                    
        }                                                                                                                                                                                                                                                      
      ],                                                                                                                                                                                                                                                       
