        },                                                                                                                                                                                                                                                     
        "models": {                                                                                                                                                                                                                                            
            "i18n": {                                                                                                                                                                                                                                          
                "type": "sap.ui.model.resource.ResourceModel",                                                                                                                                                                                                 
                "settings": {                                                                                                                                                                                                                                  
                    "bundleName": "securityDashboard.i18n.i18n"                                                                                                                                                                                                
                }                                                                                                                                                                                                                                              
            },                                                                                                                                                                                                                                                 
            "securityModel": {                                                                                                                                                                                                                                 
